<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app_main"
    android:orientation="vertical"
    android:paddingLeft="30dp"
    android:paddingRight="30dp"
    tools:context=".RegisterFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        >

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary_white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:text="PUSH YOURSELF\nTO THE LIMIT"
            android:layout_margin="20dp"/>
        <EditText
            android:id="@+id/editFirstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:hint="Enter your first name"
            android:inputType="text"
            android:padding="15dp"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark" />

        <EditText
            android:id="@+id/editLastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:hint="Enter your last name"
            android:inputType="text"
            android:padding="15dp"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark" />

        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:padding="15dp"
            android:inputType="text"
            android:hint="Enter your username"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark"
            />

        <EditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:hint="Enter your email address"
            android:inputType="textEmailAddress"
            android:padding="15dp"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark" />

        <EditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:hint="Create your password"
            android:inputType="textPassword"
            android:padding="15dp"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark" />

        <EditText
            android:id="@+id/editConfirmPass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/text_primary_white"
            android:hint="Confirm your password"
            android:inputType="textPassword"
            android:padding="15dp"
            android:textColor="@color/text_primary_white"
            android:textColorHint="@color/text_hint_dark" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Register"
            android:padding="10dp"
            android:backgroundTint="@color/brand_accent"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear"
            android:padding="10dp"
            android:backgroundTint="@color/text_secondary_gray"
            />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/loginText"
        android:textColor="@color/text_primary_white"
        android:layout_margin="10dp"
        android:textAlignment="center"/>

</LinearLayout>